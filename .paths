# Core user bins
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# PNPM global install path
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME:$PATH"

# npm global path (no sudo)
export NPM_PACKAGES="$HOME/.npm-packages"
export PATH="$PATH:$NPM_PACKAGES/bin"

# Add Bun to path
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Laravel Sail (via Linuxbrew)
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Krew (kubectl plugin manager)
export KREW_ROOT="${KREW_ROOT:-$HOME/.krew}"
export PATH="$KREW_ROOT/bin:$PATH"

# nvm path only (actual load of nvm.sh happens later)
export NVM_DIR="$HOME/.nvm"

# WSL cleanup: remove Windows Node/npm/pnpm paths
if grep -qEi "(Microsoft|WSL)" /proc/version 2>/dev/null; then
  WINDOWS_USER=$(/mnt/c/Windows/System32/cmd.exe /c 'echo %USERNAME%' 2>/dev/null | tr -d '\r')

  CLEANED_PATH=""
  OLD_IFS="$IFS"
  IFS=':'

  for entry in $PATH; do
    case "$entry" in
      "/mnt/c/Program Files/nodejs"| \
      "/mnt/c/Program Files/nodejs/"| \
      "/mnt/c/Users/$WINDOWS_USER/AppData/Roaming/npm"| \
      "/mnt/c/Users/$WINDOWS_USER/AppData/Local/pnpm"| \
      "/mnt/c/Users/$WINDOWS_USER/.config/herd/bin"| \
      "/mnt/c/Users/$WINDOWS_USER/.config/herd/bin/nvm")
        ;;
      *)
        if [ -z "$CLEANED_PATH" ]; then
          CLEANED_PATH="$entry"
        else
          CLEANED_PATH="$CLEANED_PATH:$entry"
        fi
        ;;
    esac
  done

  IFS="$OLD_IFS"
  export PATH="$CLEANED_PATH"
  unset CLEANED_PATH OLD_IFS WINDOWS_USER
fi

# Deduplicate PATH while preserving order
if command -v awk >/dev/null 2>&1; then
  PATH="$(printf '%s' "$PATH" | awk -v RS=':' -v ORS=':' '!seen[$0]++' | sed 's/:$//')"
  export PATH
fi

# Preserve MANPATH if it exists; otherwise use default
if command -v manpath >/dev/null 2>&1; then
  export MANPATH="${MANPATH-$(manpath)}:$NPM_PACKAGES/share/man"
else
  export MANPATH="${MANPATH:-}:$NPM_PACKAGES/share/man"
fi